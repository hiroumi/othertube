# Anthropic Claude API
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# YouTube Data API v3
# https://console.cloud.google.com/
YOUTUBE_API_KEY=

# X (Twitter) API Bearer Token (optional)
# https://developer.twitter.com/
X_BEARER_TOKEN=

# Supabase — X APIレスポンスの24時間キャッシュ用（任意）
# 設定すると同一アカウントの2回目以降はX APIを呼ばずにキャッシュを返す
# https://supabase.com/
#
# ⚠️ SUPABASE_SERVICE_ROLE_KEY はサーバー専用の強いキー。
#    絶対に NEXT_PUBLIC_ を付けず、ブラウザへ渡さないこと。
#
# 事前にSupabase SQL Editorで以下を実行してください:
#   create table x_profile_cache (
#     username  text primary key,
#     profile   jsonb not null,
#     cached_at timestamptz not null default now()
#   );
#   create index x_profile_cache_cached_at_idx
#     on x_profile_cache (cached_at);
#
# 期限切れデータの手動削除（件数が増えたら適宜実行）:
#   delete from x_profile_cache
#   where cached_at < now() - interval '7 days';
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
